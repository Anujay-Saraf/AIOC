# OpenAI (ChatGPT / GPT-4o) — the LLM powering agent reasoning.
# Leave blank to run fully offline in heuristic mode.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Jarvis query routing: Memgraph graph/query memory -> local Ollama
# Qwen -> selected online provider -> deterministic heuristic.
# Ollama's published Qwen 2.5 default tag here is qwen2.5:7b.
# Set OLLAMA_MODEL to another installed local tag only after pulling it on the host.
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_ANSWER_CONFIDENCE=0.68
OLLAMA_TIMEOUT_SECONDS=45
QUERY_CACHE_TTL_SECONDS=86400
QUERY_CACHE_MIN_CONFIDENCE=0.72
QUERY_CACHE_SIMILARITY_THRESHOLD=0.90
QUERY_CACHE_VERSION=graph-query-v2
GRAPH_MEMORY_BACKEND=memgraph
MEMGRAPH_URI=bolt://127.0.0.1:7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=
HIGH_IMPACT_ALERT_THRESHOLD_PER_MINUTE=1000

# Optional online fallback. LLM_PROVIDER may be openai, gemini, groq, or claude.
# The same values can be configured as an enabled connector on the Admin page.
LLM_PROVIDER=openai
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

SERVICE=payment-api
LOG_LEVEL=INFO

# Optional: Slack or Discord incoming webhook for live war-room notifications
WAR_ROOM_WEBHOOK_URL=

# Optional: Microsoft Teams Workflows/incoming webhook for high-impact alerts.
TEAMS_ALERT_WEBHOOK_URL=
TEAMS_PROJECT_OWNER=
TEAMS_ADMIN=

# Optional: SMTP settings for high-risk remediation approval email alerts.
# Leave blank to disable email alerts safely.
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_FROM=noreply@example.com
EMAIL_FROM_DOMAIN=example.com
HIGH_RISK_ALERT_EMAIL_TO=anujay.ds@gmail.com

# Optional: Slack assistant bot mode.
# Create a Slack app with slash commands, Events API, and interactivity enabled.
# Development note: set SLACK_ALLOW_UNSIGNED_LOCAL=true only for local tests.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_DEFAULT_CHANNEL=
SLACK_ALLOW_UNSIGNED_LOCAL=false

# Container runtime ports
PORT=8000
WEB_PORT=3000

# Use the public deployment domain for generated links and notifications.
PUBLIC_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
WEB_INTERNAL_URL=http://127.0.0.1:3000

# Production access control
API_AUTH_TOKEN=

RCA_DEBATE_MAX_ROUNDS=2

# Optional: open-source telemetry provider. Use "mock" or "oss".
TELEMETRY_PROVIDER=mock
PROMETHEUS_URL=
PROMETHEUS_QUERY_ERROR_RATE=error_rate{service="$service"}
PROMETHEUS_QUERY_LATENCY=latency_ms{service="$service"}
PROMETHEUS_QUERY_CPU=cpu_percent{service="$service"}
PROMETHEUS_QUERY_MEMORY=memory_mb{service="$service"}
LOKI_URL=
LOKI_QUERY={service="$service"}
ALERTMANAGER_URL=
GITLAB_URL=
GITLAB_PROJECT_ID=
GITLAB_TOKEN=

# Optional: open-source war-room providers: mattermost, zulip, matrix.
WAR_ROOM_PROVIDER=
MATTERMOST_WEBHOOK_URL=
ZULIP_URL=
ZULIP_EMAIL=
ZULIP_API_KEY=
ZULIP_STREAM=incidents
ZULIP_TOPIC=incident-response
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
MATRIX_ROOM_ID=

# Optional: review authorization.
OPA_URL=
API_AUTH_TOKEN=
KEYCLOAK_JWKS_URL=
KEYCLOAK_AUDIENCE=
